---
import MainLayout from '../layouts/MainLayout.astro';
import TrackRow from '../components/TrackRow.svelte';
import { getLibrary } from '../lib/r2.ts';

const songs = await getLibrary();
---

<MainLayout>
  <main id="library-main" data-songs={JSON.stringify(songs)} class="max-w-3xl mx-auto p-8">
    <h1 class="text-5xl md:text-6xl font-black mb-10 text-retro-gold tracking-tight drop-shadow-md">
      TUGSTUGS.
    </h1>

    <div class="flex flex-col gap-3">
      {songs.map((song: { path: string }, index: number) => (
        <TrackRow client:load path={song.path} index={index} />
      ))}
    </div>
  </main>
</MainLayout>

<script>
  import { playlist } from '../lib/store.ts';

  const mainElement = document.getElementById('library-main');
  
  if (mainElement) {
    const rawSongs = JSON.parse(mainElement.getAttribute('data-songs') || '[]');
    
    const formattedPlaylist = rawSongs.map((song: { path: string }) => ({
      path: song.path,
      title: song.path.split('/').pop()?.replace(/\.(mp3|m4a)$/i, "") || "Unknown"
    }));

    playlist.set(formattedPlaylist);
  }
</script>
