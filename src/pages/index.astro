---
import MainLayout from '../layouts/MainLayout.astro';
import { getLibrary } from '../lib/r2.ts';

const songs = await getLibrary();
---

<MainLayout>
  <div style="max-width: 800px; margin: 0 auto; padding: 2rem; color: white; font-family: sans-serif;">
    <h1 style="font-size: 3rem; font-weight: 900; margin-bottom: 2rem;">TUGSTUGS LIBRARY</h1>

    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {songs.length > 0 ? (
        songs.map((song) => (
          <div style="background: #1e1e1e; padding: 1rem 1.5rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #333;">
            
            <div>
              <strong style="display: block; font-size: 1.2rem; margin-bottom: 0.2rem;">{song.title}</strong>
              <span style="color: #a1a1aa; font-size: 0.8rem; text-transform: uppercase;">{song.path.split('/')[0]}</span>
            </div>
            
            <button 
              class="play-btn"
              data-path={song.path}
              data-title={song.title}
              style="background: white; color: black; border: none; padding: 0.5rem 1.5rem; border-radius: 20px; font-weight: bold; cursor: pointer; transition: transform 0.1s;"
              onmouseover="this.style.transform='scale(1.05)'"
              onmouseout="this.style.transform='scale(1)'"
            >
              PLAY
            </button>
            
          </div>
        ))
      ) : (
        <p style="color: #a1a1aa; font-style: italic;">No songs found in the bucket.</p>
      )}
    </div>
  </div>
</MainLayout>

<script>
  import { currentSong, currentTitle } from '../lib/store.ts';

  const buttons = document.querySelectorAll('.play-btn');

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const path = button.getAttribute('data-path');
      const title = button.getAttribute('data-title');
      
      if (path && title) {
        currentSong.set(path);
        currentTitle.set(title);
      }
    });
  });
</script>
