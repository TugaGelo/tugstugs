---
import MainLayout from '../layouts/MainLayout.astro';
import { getLibrary } from '../lib/r2.ts';

const songs = await getLibrary();
---

<MainLayout>
  <main class="max-w-3xl mx-auto p-8">
    <h1 class="text-5xl md:text-6xl font-black mb-10 text-retro-gold tracking-tight drop-shadow-md">
      TUGSTUGS.
    </h1>

    <div class="flex flex-col gap-3">
      {songs.length > 0 ? (
        songs.map((song) => (
          <div class="group flex items-center justify-between p-4 bg-black/10 hover:bg-black/20 border border-white/5 rounded-xl transition-all duration-300">
            
            <div>
              <strong class="block text-xl font-bold text-gray-50 group-hover:text-retro-gold transition-colors">
                {song.title}
              </strong>
              <span class="text-xs text-gray-400 uppercase tracking-wider">
                {song.path.split('/')[0]}
              </span>
            </div>
            
            <button 
              class="play-btn bg-retro-gold text-retro-slate font-black py-2 px-6 rounded-full hover:bg-retro-orange hover:text-white hover:scale-105 transition-all shadow-lg cursor-pointer"
              data-path={song.path}
              data-title={song.title}
            >
              PLAY
            </button>
            
          </div>
        ))
      ) : (
        <div class="p-8 border-2 border-dashed border-retro-coral/50 rounded-xl text-center">
          <p class="text-retro-coral font-medium italic">No tapes found in the deck.</p>
        </div>
      )}
    </div>
  </main>
</MainLayout>

<script>
  import { currentSong, currentTitle, playlist, currentIndex } from '../lib/store.ts';

  const buttons = Array.from(document.querySelectorAll('.play-btn'));

  const songsArray = buttons.map(btn => ({
    path: btn.getAttribute('data-path') || '',
    title: btn.getAttribute('data-title') || ''
  }));
  
  playlist.set(songsArray);

  buttons.forEach((button, index) => {
    button.addEventListener('click', () => {
      const path = button.getAttribute('data-path');
      const title = button.getAttribute('data-title');
      
      if (path && title) {
        currentSong.set(path);
        currentTitle.set(title);
        currentIndex.set(index);
      }
    });
  });
</script>
