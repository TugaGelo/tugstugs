---
import MainLayout from '../../layouts/MainLayout.astro';
import AlbumView from '../../components/AlbumView.svelte';
import { getLibrary } from '../../lib/r2.ts';

const { album } = Astro.params;

const cfEnv = (Astro.locals as any).runtime?.env;

const allSongs = await getLibrary(cfEnv);

const albumSongs = allSongs.filter(song => {
  const parts = song.path.split('/');
  const songAlbumName = parts.length > 1 ? parts[0] : 'Singles';
  return songAlbumName === album;
});

const rawPaths = albumSongs.map(song => song.path);
---

<MainLayout>
  <main class="max-w-6xl mx-auto p-6 md:p-10 pt-4">
    
    <a href="/" class="inline-flex items-center text-gray-400 hover:text-white transition-colors mb-8 text-sm font-bold tracking-widest uppercase cursor-pointer">
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 mr-2"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      Library
    </a>
    
    <AlbumView client:load albumName={album} rawPaths={rawPaths} />

  </main>
</MainLayout>
